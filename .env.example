# Backend selection: fake | anthropic | local
LLM_BACKEND=fake

# Anthropic API (required only when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local llama-server / Ollama (required only when LLM_BACKEND=local)
# Must be OpenAI-compatible endpoint (path ending in /v1)
LOCAL_LLM_URL=http://192.168.3.92:8080/v1
LOCAL_LLM_MODEL=Qwen2.5-Coder-7B-Instruct-Q4_K_M.gguf

DATABASE_URL=sqlite:///./balance_studio.db

# Simulation cache backend: disk (dev, per-scenario files) | redis (prod)
CACHE_BACKEND=disk
CACHE_DIR=./.diskcache
# Required only when CACHE_BACKEND=redis
REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=INFO

# --- Deploy security (see docs/security-review.md) ---
# API key required on POST/PATCH/DELETE. Unset = dev mode (writes open, logs a warning).
BALANCE_API_KEY=
# Comma-separated CORS allow-list. Unset defaults to http://localhost:3000 (dev).
ALLOWED_ORIGINS=http://localhost:3000
# Per-IP write rate limit (requests/minute).
WRITE_RATE_LIMIT_PER_MIN=60
