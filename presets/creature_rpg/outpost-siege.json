{
 "id": "outpost-siege",
 "name": "Outpost Siege",
 "domain": "creature_rpg",
 "description": "Inspired by survival-horror shooters like Resident Evil. Reinterprets `creature_rpg` as arsenal-vs-hostiles: weapons (glass-cannon shotgun, balanced rifle, durable pistol) fighting zombie types (fodder shambler, fast rusher, armored crawler). Explore: does shotgun dominate fodder while losing to armored? Is rifle a boring generalist? Which weapon dies first in ammo-constrained sim?",
 "schema_overrides": {
  "fields": [
   {
    "name": "hp",
    "range": [
     20,
     220
    ],
    "description": "Durability / magazine size (weapon) or health pool (zombie)"
   },
   {
    "name": "atk",
    "range": [
     20,
     150
    ],
    "description": "Damage per shot (weapon) or bite damage (zombie)"
   },
   {
    "name": "defense",
    "range": [
     10,
     110
    ],
    "description": "Recoil control / handling (weapon) or armor (zombie)"
   }
  ]
 },
 "default_constraints": [],
 "default_objectives": [
  {
   "metric_name": "winrate_std",
   "direction": "minimize",
   "weight": 1.0
  }
 ],
 "default_visual_variant": "creature_rpg.default",
