{
 "id": "cover-firefight",
 "name": "Cover Firefight",
 "domain": "creature_rpg",
 "description": "Inspired by cover-based shooters like Gears of War. Reinterprets `creature_rpg` as loadout-vs-hostiles: 4 diverse weapons (rapid-fire lancer, close-burst gnasher, precision longshot, devastating heavy) fighting Locust-flavored threats (grunt drone, fragile-rusher wretch, tank-lobbing boomer). Explore: does any weapon become mandatory (kills niche design)? Is the heavy overpowered given its fragility trade-off? Which threat trivializes which weapon?",
 "schema_overrides": {
  "fields": [
   {
    "name": "hp",
    "range": [
     15,
     220
    ],
    "description": "Reliability / effective range (weapon) or health (threat)"
   },
   {
    "name": "atk",
    "range": [
     30,
     160
    ],
    "description": "Damage per engagement"
   },
   {
    "name": "defense",
    "range": [
     10,
     110
    ],
    "description": "Handling stability (weapon) or armor (threat)"
   }
  ]
 },
 "default_constraints": [],
 "default_objectives": [
  {
   "metric_name": "winrate_std",
   "direction": "minimize",
   "weight": 1.0
  }
 ],
 "default_visual_variant": "creature_rpg.default",
