{
 "id": "multi-color-tcg",
 "name": "Multi-color Strategy TCG",
 "domain": "card_game",
 "description": "Inspired by tabletop TCGs like Magic: The Gathering. Creatures with mana value 0-10 and power/toughness 1-15; keyword abilities are mapped onto the engine primitives.",
 "schema_overrides": {
  "fields": [
   {
    "name": "cost",
    "range": [
     0,
     10
    ],
    "description": "Mana value (converted mana cost)"
   },
   {
    "name": "damage",
    "range": [
     1,
     15
    ],
    "description": "Power"
   },
   {
    "name": "hp",
    "range": [
     1,
     15
    ],
    "description": "Toughness"
   },
   {
    "name": "ability_kind",
    "enum": [
     "direct_damage",
     "restore_life",
     "negate",
     "card_draw"
    ],
    "description": "Keyword ability"
   },
   {
    "name": "ability_value",
    "range": [
     0,
     10
    ]
   }
  ]
 },
 "sim_config": {
  "ability_map": {
   "direct_damage": "deal_damage",
   "restore_life": "heal",
   "negate": "shield",
   "card_draw": "draw"
  }
 },
 "default_constraints": [],
 "default_objectives": [
  {
   "metric_name": "winrate_std",
   "direction": "minimize",
   "weight": 1.0
  }
 ],
 "default_visual_variant": "card_game.default",
 "examples": [
  {
   "name": "Voltaic Wisp",
   "cost": 4,
   "hp": 1,
   "damage": 4,
   "ability_kind": "direct_damage",
   "ability_value": 3,
   "description": "Hasty red beater."
  },
  {
   "name": "Radiant Seraph",
   "cost": 5,
   "hp": 4,
   "damage": 4,
   "ability_kind": "restore_life",
   "ability_value": 2,
   "description": "Flying vigilant lifegain."
  },
  {
   "name": "Warding Sentinel",
   "cost": 2,
   "hp": 4,
   "damage": 1,
   "ability_kind": "card_draw",
   "ability_value": 1,
   "description": "Draws a card on entry."
  }
 ]
}
