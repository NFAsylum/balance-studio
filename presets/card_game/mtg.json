{
 "id": "mtg",
 "name": "Magic: The Gathering",
 "domain": "card_game",
 "description": "Creatures with mana value 0-10 and power/toughness 1-15, with MTG-flavoured ability names mapped onto the engine primitives.",
 "schema_overrides": {
  "fields": [
   {
    "name": "cost",
    "range": [
     0,
     10
    ],
    "description": "Mana value (converted mana cost)"
   },
   {
    "name": "damage",
    "range": [
     1,
     15
    ],
    "description": "Power"
   },
   {
    "name": "hp",
    "range": [
     1,
     15
    ],
    "description": "Toughness"
   },
   {
    "name": "ability_kind",
    "enum": [
     "burn",
     "lifegain",
     "counter",
     "cantrip"
    ],
    "description": "Keyword ability"
   },
   {
    "name": "ability_value",
    "range": [
     0,
     10
    ]
   }
  ]
 },
 "sim_config": {
  "ability_map": {
   "burn": "deal_damage",
   "lifegain": "heal",
   "counter": "shield",
   "cantrip": "draw"
  }
 },
 "default_constraints": [
  {
   "kind": "range",
   "params": {
    "field": "cost",
    "min": 0,
    "max": 10
   }
  }
 ],
 "default_objectives": [
  {
   "metric_name": "winrate_std",
   "direction": "minimize",
   "weight": 1.0
  }
 ],
 "default_visual_variant": "card_game.default",
 "examples": [
  {
   "name": "Lightning Elemental",
   "cost": 4,
   "hp": 1,
   "damage": 4,
   "ability_kind": "burn",
   "ability_value": 3,
   "description": "Hasty red beater."
  },
  {
   "name": "Serra Angel",
   "cost": 5,
   "hp": 4,
   "damage": 4,
   "ability_kind": "lifegain",
   "ability_value": 2,
   "description": "Flying vigilant lifegain."
  },
  {
   "name": "Wall of Omens",
   "cost": 2,
   "hp": 4,
   "damage": 1,
   "ability_kind": "cantrip",
   "ability_value": 1,
   "description": "Draws a card on entry."
  }
 ]
}
